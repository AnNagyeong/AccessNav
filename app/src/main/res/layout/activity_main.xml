<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <WebView
        android:id="@+id/webMap"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 상단 검색바 -->
    <LinearLayout
        android:id="@+id/topSearchWrap"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_round_24_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_menu_24"
            android:tint="@color/gray_500" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="장소를 입력하세요"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/black"
            android:textColorHint="@color/gray_500"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/btnClear"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_close_20"
            android:tint="@color/gray_500" />
    </LinearLayout>

    <!-- 칩 -->
    <LinearLayout
        android:id="@+id/chipRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/topSearchWrap"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/chipTaxi"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_round_16_chip"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_taxi_16"
                android:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="택시 정류장"
                android:textColor="@color/chip_text"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/chipStore"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_round_16_chip"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_store_16"
                android:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="편의점"
                android:textColor="@color/chip_text"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/chipCafe"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_round_16_chip"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_cafe_16"
                android:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="카페"
                android:textColor="@color/chip_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 오른쪽 버튼 2개 -->
    <LinearLayout
        android:id="@+id/rightActionWrap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/topSearchWrap"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnFavorite"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_round_18_white"
            android:elevation="6dp"
            android:padding="10dp"
            android:src="@drawable/ic_star_24"
            android:tint="@color/gray_500" />

        <ImageView
            android:id="@+id/btnFilter"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_round_18_white"
            android:elevation="6dp"
            android:padding="10dp"
            android:src="@drawable/ic_layers_24"
            android:tint="@color/gray_500" />
    </LinearLayout>

    <!-- 줌 버튼 -->
    <LinearLayout
        android:id="@+id/zoomWrap"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:background="@drawable/bg_round_18_white"
        android:elevation="6dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnZoomIn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:padding="10dp"
            android:src="@drawable/ic_zoom_in_24"
            android:tint="@color/gray_500" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E5E5" />

        <ImageView
            android:id="@+id/btnZoomOut"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:padding="10dp"
            android:src="@drawable/ic_zoom_out_24"
            android:tint="@color/gray_500" />
    </LinearLayout>

    <!-- 예시 마커 오버레이 들어가는 부분인데 보류 -->

    <!-- 좌하단 개수 -->
    <LinearLayout
        android:id="@+id/spotCountWrap"
        android:layout_width="52dp"
        android:layout_height="28dp"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="90dp"
        android:background="@drawable/bg_round_18_white"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_weather_16"
            android:tint="@color/gray_500"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/spotCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="16"
            android:textColor="@color/black"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 하단 네비 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@color/white"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home_24"
                android:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAccessibility"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_accessibility_24"
                android:tint="@color/gray_500" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCamera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_camera_24"
                android:tint="@color/gray_500" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person_24"
                android:tint="@color/gray_500" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>